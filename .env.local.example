# URL de déploiement du script Google Apps Script
# Obtenue après avoir cliqué sur "Déployer > Nouvelle version" dans l'éditeur GAS
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/VOTRE_DEPLOYMENT_ID/exec

# Préfixe du dépôt GitHub Pages (ex: /sig-platform si repo s'appelle sig-platform)
# Laisser vide si déployé à la racine
NEXT_PUBLIC_BASE_PATH=
